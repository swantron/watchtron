# Control plane
WATCHTRON_PORT=4318
# Bearer token required on /v1/traces (ingest) and /verify, /badge (read).
# Generate one: openssl rand -hex 32
WATCHTRON_TOKEN=change-me

# Prober
# Where the prober ships its OTLP/HTTP JSON spans (the control plane receiver).
WATCHTRON_OTLP_ENDPOINT=http://localhost:4318
# Token used by the prober when shipping spans + when querying /verify.
WATCHTRON_TOKEN=change-me
